# FinPME — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env com credenciais reais

# ── Banco de dados ───────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finpme
DB_USER=finpme
DB_PASSWORD=

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT ──────────────────────────────────────────────────────────────────────
# Mínimo 32 caracteres. Gere com: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRATION_HOURS=24

# ── Pluggy (Open Finance) ────────────────────────────────────────────────────
# Crie sua conta em: https://pluggy.ai
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=

# ── WhatsApp Business API (Meta) ─────────────────────────────────────────────
# Crie seu app em: https://developers.facebook.com
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── BrasilAPI ────────────────────────────────────────────────────────────────
# Pública e gratuita — sem credenciais necessárias
BRASILAPI_BASE_URL=https://brasilapi.com.br
