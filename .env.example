# =============================================================
# FinPME — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env com valores reais
# =============================================================

# --- Aplicação ---
NODE_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000

# --- Banco de Dados (PostgreSQL) ---
DATABASE_URL=postgresql://finpme_user:senha_aqui@localhost:5432/finpme_dev
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finpme_dev
DB_USER=finpme_user
DB_PASSWORD=senha_aqui

# --- Cache (Redis) ---
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Autenticação ---
JWT_SECRET=troque_por_um_segredo_forte_de_pelo_menos_32_chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=outro_segredo_forte_para_refresh_token
REFRESH_TOKEN_EXPIRES_IN=30d

# --- E-mail (SMTP) ---
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=seu_usuario_smtp
SMTP_PASS=sua_senha_smtp
SMTP_FROM=noreply@finpme.com.br

# --- Armazenamento (S3-compatible) ---
STORAGE_PROVIDER=local          # local | s3 | r2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=finpme-dev
AWS_REGION=us-east-1

# --- Integrações Financeiras ---
OPEN_FINANCE_CLIENT_ID=
OPEN_FINANCE_CLIENT_SECRET=
OPEN_FINANCE_REDIRECT_URI=http://localhost:3000/api/open-finance/callback

# --- Monitoramento ---
SENTRY_DSN=
LOG_LEVEL=debug
