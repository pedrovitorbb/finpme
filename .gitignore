# =============================================================
# FinPME — .gitignore
# =============================================================

# Variáveis de ambiente reais
.env
.env.local
.env.*.local
!.env.example

# Dependências
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml

# Build outputs
dist/
build/
out/
.next/
.nuxt/
.output/

# Cache e temporários
.cache/
.turbo/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Python (caso usado em scripts)
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/

# Banco de dados local
*.sqlite
*.sqlite3
*.db

# Cobertura de testes
coverage/
.nyc_output/
lcov.info

# IDE e editores
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# Arquivos de chave e certificados
*.pem
*.key
*.cert
*.p12

# Uploads e armazenamento local
uploads/
storage/local/

# Prisma (manter schema, ignorar gerados)
backend/src/generated/

# Docker volumes locais
.docker-data/
